{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "lib": ["WebWorker", "ES2022"],
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["src/worker.ts", "src/repositories/d1KnowledgeStore.ts", "src/repositories/knowledgeStore.ts", "src/services/knowledgeEngine.ts", "src/services/transactionManager.ts", "src/types/index.ts", "src/lib/errors.ts", "src/lib/schema.ts", "src/types/index.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}
